#include <stdio.h>
#include <string.h>
#include <stdlib.h>
#include <unistd.h>
#include <sys/wait.h>
#include <ctype.h>

#define MAX_ARGS 64

// Simple tokenizer that handles quotes
int parse_input(char *input, char *args[])
{
	int i = 0;
	char *p = input;

	while (*p)
	{
		while (isspace(*p))
			p++;

		if (*p == '\0')
			break;

		if (*p == '"' || *p == '\'')
		{
			char quote = *p++;
			args[i++] = p;

			while (*p && *p != quote)
				p++;

			if (*p)
			{
				*p = '\0';
				p++;
			}
		}
		else
		{
			args[i++] = p;

			while (*p && !isspace(*p))
				p++;

			if (*p)
			{
				*p = '\0';
				p++;
			}
		}

		if (i >= MAX_ARGS - 1)
			break;
	}

	args[i] = NULL;
	return i;
}

int main(void)
{
	char cmnd[1024];
	char u[32];
	char cwd[1024];
	char *args[MAX_ARGS];
	pid_t pid;

	printf("enter your user name: ");
	scanf("%31s", u);
	getchar();

	while (1)
	{
		if (getcwd(cwd, sizeof(cwd)) == NULL)
		{
			perror("getcwd");
			continue;
		}

		printf("%s@mini_shell %s> ", u, cwd);

		if (fgets(cmnd, sizeof(cmnd), stdin) == NULL)
			break;

		cmnd[strcspn(cmnd, "\n")] = 0;

		parse_input(cmnd, args);

		if (args[0] == NULL)
			continue;

		if (strcmp(args[0], "cd") == 0)
		{
			if (args[1] == NULL)
			{
				char *home = getenv("HOME");
				if (!home)
					printf("cd: HOME not set\n");
				else if (chdir(home) != 0)
					perror("cd");
			}
			else if (chdir(args[1]) != 0)
				perror("cd");
		}
		else if (strcmp(args[0], "pwd") == 0)
		{
			if (getcwd(cwd, sizeof(cwd)) == NULL)
				perror("pwd");
			else
				printf("%s\n", cwd);
		}
		else if (strcmp(args[0], "exit") == 0)
			break;
		else
		{
			pid = fork();
			if (pid == 0)
			{
				execvp(args[0], args);
				perror("execvp");
				exit(1);
			}
			else if (pid < 0)
				perror("fork");
			else
				waitpid(pid, NULL, 0);
		}
	}

	return 0;
}
